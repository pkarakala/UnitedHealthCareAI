# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxx
DEFAULT_MODEL=claude-haiku-4-5-20251001
MAX_TOKENS=2048

# Database
DATABASE_URL=postgresql+asyncpg://pa_user:pa_pass@db:5432/prior_auth

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=your-secret-key-change-in-production
ENCRYPTION_KEY=your-32-byte-encryption-key-here
# Salt for the PHI-encryption KDF. Keep constant for the life of the data —
# changing it renders existing encrypted PHI undecryptable.
ENCRYPTION_SALT=change-me-to-a-random-salt

# Langfuse (LLM Observability)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000

# Application
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,https://usahealthcare.ai
