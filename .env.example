# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Database
DATABASE_URL=postgresql+asyncpg://pa_user:pa_pass@db:5432/prior_auth

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=your-secret-key-change-in-production
